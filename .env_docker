# BACKEND
DEV=true
ENV_FOR_DYNACONF=default

DATABASE=postgres
SQL_HOST=db
SQL_PORT=5432
POSTGRES_DB=budgetory_db
POSTGRES_USER=budgetory_user
POSTGRES_PASSWORD=budgetory_password

# FRONTEND
REACT_APP_BACKEND_URL=http://localhost:8000
# Lifetime values in seconds
REACT_APP_ACCESS_TOKEN_LIFETIME=3600
REACT_APP_REFRESH_TOKEN_LIFETIME=86400